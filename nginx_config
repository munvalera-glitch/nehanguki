# Redirect all HTTP to HTTPS non-www
server {
    listen 80;
    listen [::]:80;
    server_name hikoreaforms.com www.hikoreaforms.com;
    return 301 https://hikoreaforms.com$request_uri;
}

# Redirect HTTPS www to HTTPS non-www
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name www.hikoreaforms.com;

    ssl_certificate /etc/letsencrypt/live/hikoreaforms.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hikoreaforms.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://hikoreaforms.com$request_uri;
}

# Main Site Block
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name hikoreaforms.com;

    ssl_certificate /etc/letsencrypt/live/hikoreaforms.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hikoreaforms.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/hikoreaforms/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /auth/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_cache_bypass $http_upgrade;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_cache_bypass $http_upgrade;
        client_max_body_size 20M;
    }
}
